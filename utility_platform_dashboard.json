    "9": {
      "title": "🏗️ Service Health Assessment - $Namespace",
      "type": "data",
      "query": "fetch spans\n| filter k8s.namespace.name == $Namespace\n| filter request.is_root_span == true\n| fieldsAdd service_name = entityName(dt.entity.service)\n| summarize\n    total = count(),\n    errors = countIf(request.is_failed == true),\n    slow = countIf(duration > 3000000000),\n    avg_duration = avg(duration),\n    p95_duration = percentile(duration, 95),\n    by: {service_name}\n| fieldsAdd\n    error_rate = round((errors * 100.0) / total, decimals:2),\n    slow_rate = round((slow * 100.0) / total, decimals:2)\n| fieldsAdd\n    health = if(\n        error_rate < 1.0 and slow_rate < 5.0, \"✅ Healthy\",\n        else: if(error_rate < 5.0, \"⚠️ Degraded\", else: \"🔴 Critical\")\n    )\n| sort error_rate desc\n| fields service_name, health, total, errors, error_rate, p95_duration",
      "visualization": "table",
      "visualizationSettings": {
        "thresholds": [],
        "unitsOverrides": [
          {
            "identifier": "p95_duration",
            "unitCategory": "time",
            "baseUnit": "nanosecond",
            "displayUnit": null,
